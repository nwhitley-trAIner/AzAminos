# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host.neon.tech/azaminos?sslmode=require"

# Admin JWT Secret (generate with: openssl rand -base64 32)
ADMIN_JWT_SECRET="change-me-to-a-random-secret"

# Payment Processor Configuration
# Options: mock | authorize_net | nmi | coinbase
PAYMENT_PROCESSOR="mock"

# Authorize.net (when approved)
AUTHORIZE_NET_API_LOGIN_ID=""
AUTHORIZE_NET_TRANSACTION_KEY=""
AUTHORIZE_NET_SANDBOX="true"

# NMI (when approved)
NMI_SECURITY_KEY=""
NMI_SANDBOX="true"

# Coinbase Commerce (crypto payments)
COINBASE_COMMERCE_API_KEY=""
COINBASE_COMMERCE_WEBHOOK_SECRET=""

# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="AZ Aminos"

# Stock Reservation TTL (minutes)
STOCK_RESERVATION_TTL_MINUTES="15"
